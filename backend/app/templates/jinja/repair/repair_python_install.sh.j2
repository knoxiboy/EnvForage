#!/bin/bash
# ==============================================================================
# EnvForage Repair Script — Python Version Install
# Generated: {{ generated_at }}
# EnvForage : v{{ envforage_version }}
#
# This script installs the target Python version using pyenv or
# the system package manager. It does NOT remove existing versions.
#
# ⚠ WARNING: Review this script before running.
#
# Usage:
#   chmod +x repair_python_install.sh && ./repair_python_install.sh
# ==============================================================================

set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
info()  { echo -e "${GREEN}[EnvForage Repair]${NC} $1"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1" >&2; exit 1; }

TARGET_PYTHON="{{ target_python_version | default('3.11') }}"

# ── Confirmation ──────────────────────────────────────────────────────────────
echo ""
info "EnvForage Python Install Repair Script"
info "Target Python version: $TARGET_PYTHON"
echo ""
read -p "Do you want to proceed? [y/N]: " CONFIRM
if [[ "${CONFIRM,,}" != "y" ]]; then
    info "Aborted by user."
    exit 0
fi

# ── Step 1: Check current Python ─────────────────────────────────────────────
info "Step 1/3: Checking existing Python installations..."
for py in python3 python python3.8 python3.9 python3.10 python3.11 python3.12; do
    if command -v "$py" &>/dev/null; then
        PY_VER=$("$py" --version 2>&1)
        info "  Found: $PY_VER at $(command -v $py)"
    fi
done

# ── Step 2: Install via pyenv (preferred) ─────────────────────────────────────
info "Step 2/3: Installing Python $TARGET_PYTHON..."

if command -v pyenv &>/dev/null; then
    info "pyenv detected. Installing Python $TARGET_PYTHON via pyenv..."
    pyenv install "$TARGET_PYTHON" --skip-existing
    pyenv local "$TARGET_PYTHON"
    info "Python $TARGET_PYTHON installed and set as local version."
else
    warn "pyenv not found. Attempting system package manager..."

    if command -v apt-get &>/dev/null; then
        info "Using apt to install Python $TARGET_PYTHON..."
        sudo apt-get update
        sudo apt-get install -y "python${TARGET_PYTHON}" "python${TARGET_PYTHON}-venv" "python${TARGET_PYTHON}-dev"
    elif command -v dnf &>/dev/null; then
        info "Using dnf to install Python $TARGET_PYTHON..."
        sudo dnf install -y "python${TARGET_PYTHON}" "python${TARGET_PYTHON}-devel"
    else
        error "No supported package manager found. Install pyenv: https://github.com/pyenv/pyenv"
    fi
fi

# ── Step 3: Verify ────────────────────────────────────────────────────────────
info "Step 3/3: Verifying installation..."
if command -v "python${TARGET_PYTHON}" &>/dev/null; then
    info "Python $TARGET_PYTHON installed successfully:"
    "python${TARGET_PYTHON}" --version
else
    warn "python${TARGET_PYTHON} not in PATH. You may need to restart your shell."
fi

echo ""
info "Repair script complete."
