#!/bin/bash
# ==============================================================================
# EnvForage Repair Script — Virtual Environment Recreate
# Generated: {{ generated_at }}
# EnvForage : v{{ envforage_version }}
#
# This script backs up and recreates a Python virtual environment.
# The old venv is renamed (not deleted) for safety.
#
# ⚠ WARNING: Review this script before running.
#
# Usage:
#   chmod +x repair_venv_recreate.sh && ./repair_venv_recreate.sh
# ==============================================================================

set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
info()  { echo -e "${GREEN}[EnvForage Repair]${NC} $1"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1" >&2; exit 1; }

PYTHON_BIN="{{ python_bin | default('python3') }}"
VENV_DIR="{{ venv_dir | default('.venv') }}"

echo ""
info "EnvForage Virtual Environment Recreate Script"
info "Python: $PYTHON_BIN"
info "Venv directory: $VENV_DIR"
echo ""
read -p "This will back up and recreate $VENV_DIR. Proceed? [y/N]: " CONFIRM
if [[ "${CONFIRM,,}" != "y" ]]; then
    info "Aborted by user."
    exit 0
fi

# ── Step 1: Export current packages ───────────────────────────────────────────
info "Step 1/4: Exporting current package list..."
if [ -d "$VENV_DIR" ] && [ -f "$VENV_DIR/bin/pip" ]; then
    "$VENV_DIR/bin/pip" freeze > requirements_backup.txt 2>/dev/null || true
    info "Package list saved to requirements_backup.txt"
else
    warn "No existing venv found. Starting fresh."
fi

# ── Step 2: Back up old venv ──────────────────────────────────────────────────
info "Step 2/4: Backing up old virtual environment..."
if [ -d "$VENV_DIR" ]; then
    BACKUP_NAME="${VENV_DIR}_backup_$(date +%Y%m%d_%H%M%S)"
    mv "$VENV_DIR" "$BACKUP_NAME"
    info "Old venv moved to $BACKUP_NAME"
fi

# ── Step 3: Create new venv ───────────────────────────────────────────────────
info "Step 3/4: Creating new virtual environment..."
"$PYTHON_BIN" -m venv "$VENV_DIR"
info "New venv created at $VENV_DIR"

# Upgrade pip
"$VENV_DIR/bin/pip" install --upgrade pip setuptools wheel

# ── Step 4: Verify ────────────────────────────────────────────────────────────
info "Step 4/4: Verifying new environment..."
"$VENV_DIR/bin/python" --version
info "pip version: $($VENV_DIR/bin/pip --version)"

echo ""
info "Repair complete. To reinstall packages:"
info "  source $VENV_DIR/bin/activate"
info "  pip install -r requirements_backup.txt"
echo ""
info "To delete the old venv backup:"
info "  rm -r $BACKUP_NAME"
