#!/bin/bash
# ==============================================================================
# EnvForage Repair Script — CUDA Toolkit Upgrade
# Generated: {{ generated_at }}
# EnvForage : v{{ envforage_version }}
#
# This script upgrades the CUDA toolkit to the target version.
# It will NOT remove existing CUDA installations (they coexist).
#
# ⚠ WARNING: Review this script before running. You are responsible
#   for any changes made to your system.
#
# Usage:
#   chmod +x repair_cuda_upgrade.sh && ./repair_cuda_upgrade.sh
# ==============================================================================

set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
info()  { echo -e "${GREEN}[EnvForage Repair]${NC} $1"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1" >&2; exit 1; }

TARGET_CUDA="{{ target_cuda_version | default('12.1') }}"

# ── Confirmation ──────────────────────────────────────────────────────────────
echo ""
info "EnvForage CUDA Upgrade Repair Script"
info "Target CUDA version: $TARGET_CUDA"
echo ""
read -p "Do you want to proceed? [y/N]: " CONFIRM
if [[ "${CONFIRM,,}" != "y" ]]; then
    info "Aborted by user."
    exit 0
fi

# ── Step 1: Check current CUDA version ────────────────────────────────────────
info "Step 1/4: Checking current CUDA installation..."
if command -v nvcc &>/dev/null; then
    CURRENT_CUDA=$(nvcc --version | grep -oP 'V\K[\d.]+' | head -1)
    info "Current CUDA: $CURRENT_CUDA"
else
    warn "nvcc not found. CUDA may not be installed."
    CURRENT_CUDA="none"
fi

# ── Step 2: Check NVIDIA driver ───────────────────────────────────────────────
info "Step 2/4: Checking NVIDIA driver..."
if command -v nvidia-smi &>/dev/null; then
    DRIVER_VER=$(nvidia-smi --query-gpu=driver_version --format=csv,noheader | head -1)
    info "NVIDIA driver: $DRIVER_VER"
else
    error "nvidia-smi not found. Please install NVIDIA drivers first."
fi

# ── Step 3: Download CUDA toolkit ─────────────────────────────────────────────
info "Step 3/4: Setting up CUDA $TARGET_CUDA repository..."

# Detect OS
if [ -f /etc/os-release ]; then
    . /etc/os-release
    OS_ID="$ID"
    OS_VERSION_ID="$VERSION_ID"
else
    error "Cannot detect OS. /etc/os-release not found."
fi

info "Detected OS: $OS_ID $OS_VERSION_ID"
info "Adding NVIDIA CUDA repository..."
info "Visit https://developer.nvidia.com/cuda-$TARGET_CUDA-download to get the"
info "installation instructions specific to your OS and architecture."

# ── Step 4: Verify ────────────────────────────────────────────────────────────
info "Step 4/4: Post-install instructions"
echo ""
info "After installing CUDA $TARGET_CUDA:"
info "  1. Add to PATH:   export PATH=/usr/local/cuda-$TARGET_CUDA/bin:\$PATH"
info "  2. Add to LD:     export LD_LIBRARY_PATH=/usr/local/cuda-$TARGET_CUDA/lib64:\$LD_LIBRARY_PATH"
info "  3. Verify:        nvcc --version"
info "  4. Reboot if needed: sudo reboot"
echo ""
info "Repair script complete. Please follow the steps above."
