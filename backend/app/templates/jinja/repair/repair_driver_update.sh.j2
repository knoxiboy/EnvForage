#!/bin/bash
# ==============================================================================
# EnvForage Repair Script — NVIDIA Driver Update
# Generated: {{ generated_at }}
# EnvForage : v{{ envforage_version }}
#
# This script checks and guides the user through updating NVIDIA GPU drivers.
# It does NOT auto-install drivers (requires system-specific steps).
#
# ⚠ WARNING: Review this script before running.
#
# Usage:
#   chmod +x repair_driver_update.sh && ./repair_driver_update.sh
# ==============================================================================

set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
info()  { echo -e "${GREEN}[EnvForage Repair]${NC} $1"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1" >&2; exit 1; }

MIN_DRIVER="{{ min_driver_version | default('525.0') }}"

echo ""
info "EnvForage NVIDIA Driver Update Repair Script"
info "Minimum required driver: $MIN_DRIVER"
echo ""

# ── Step 1: Detect current driver ─────────────────────────────────────────────
info "Step 1/3: Detecting current NVIDIA driver..."

if command -v nvidia-smi &>/dev/null; then
    DRIVER_VER=$(nvidia-smi --query-gpu=driver_version --format=csv,noheader | head -1)
    GPU_NAME=$(nvidia-smi --query-gpu=name --format=csv,noheader | head -1)
    info "GPU: $GPU_NAME"
    info "Current driver: $DRIVER_VER"
    info "Required minimum: $MIN_DRIVER"
else
    error "nvidia-smi not found. NVIDIA drivers may not be installed."
fi

# ── Step 2: Compare versions ─────────────────────────────────────────────────
info "Step 2/3: Comparing driver versions..."

CURRENT_MAJOR=$(echo "$DRIVER_VER" | cut -d'.' -f1)
REQUIRED_MAJOR=$(echo "$MIN_DRIVER" | cut -d'.' -f1)

if [ "$CURRENT_MAJOR" -ge "$REQUIRED_MAJOR" ]; then
    info "Driver version $DRIVER_VER meets the minimum requirement ($MIN_DRIVER)."
    info "No driver update needed."
else
    warn "Driver $DRIVER_VER is BELOW the minimum required $MIN_DRIVER."
    echo ""
    info "Step 3/3: Update instructions"
    echo ""
    info "Option A — Ubuntu/Debian:"
    info "  sudo apt-get update"
    info "  sudo ubuntu-drivers autoinstall"
    info "  sudo reboot"
    echo ""
    info "Option B — Official NVIDIA .run installer:"
    info "  1. Download from: https://www.nvidia.com/Download/index.aspx"
    info "  2. Stop display manager: sudo systemctl stop gdm3"
    info "  3. Run installer: sudo bash NVIDIA-Linux-x86_64-*.run"
    info "  4. Reboot: sudo reboot"
    echo ""
    info "Option C — NVIDIA repository (recommended):"
    info "  Visit: https://developer.nvidia.com/cuda-downloads"
    info "  The CUDA toolkit installer includes the latest compatible driver."
fi

echo ""
info "Repair script complete."
