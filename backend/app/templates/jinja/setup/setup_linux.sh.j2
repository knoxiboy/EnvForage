#!/bin/bash
# ==============================================================================
# EnvForge Generated Setup Script — Linux / WSL
# Profile  : {{ profile.name }}
# OS Target: {{ target_os }}
# Python   : {{ python_version }}
{% if cuda_version %}# CUDA     : {{ cuda_version }}
{% endif %}# Generated: {{ generated_at }}
# EnvForge : v{{ envforge_version }}
#
# ⚠ WARNING: Review this script before running.
#   EnvForge generates safe, version-pinned scripts, but you are responsible
#   for your system. Run in a virtual environment.
#
# Usage:
#   chmod +x setup.sh && ./setup.sh
# ==============================================================================

set -euo pipefail   # Exit on error, unset vars, pipe failures

# ── Color output ──────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
info()    { echo -e "${GREEN}[EnvForge]${NC} $1"; }
warn()    { echo -e "${YELLOW}[WARN]${NC} $1"; }
error()   { echo -e "${RED}[ERROR]${NC} $1" >&2; exit 1; }

{% if use_micromamba %}
# ── Bootstrap micromamba ─────────────────────────────────────────────────────
info "Bootstrapping micromamba..."
if ! command -v micromamba >/dev/null 2>&1; then
    mkdir -p ~/.local/bin
    curl -Ls https://micro.mamba.pm/api/micromamba/linux-64/latest | tar -xvj -f - --strip-components=1 -C ~/.local/bin/
    chmod +x ~/.local/bin/micromamba
    export PATH="$HOME/.local/bin:$PATH"
    info "micromamba installed."
else
    info "micromamba already installed: $(micromamba --version)"
fi

# ── Micromamba environment ───────────────────────────────────────────────────
ENV_PREFIX="$PWD/.venv"
if [[ ! -d "$ENV_PREFIX" ]]; then
    info "Creating micromamba environment in $ENV_PREFIX..."
    micromamba create -p "$ENV_PREFIX" -c conda-forge python={{ python_version }} -y
fi
info "Micromamba environment ready: $ENV_PREFIX"
RUN_CMD="micromamba run -p $ENV_PREFIX "
{% else %}
# ── Pre-flight checks ─────────────────────────────────────────────────────────
info "Starting pre-flight checks..."

# Python version check
REQUIRED_PYTHON="{{ python_version }}"
PYTHON_BIN=""
for py in python{{ python_version }} python3 python; do
    if command -v "$py" >/dev/null 2>&1; then
        PY_VER=$("$py" --version 2>&1 | cut -d' ' -f2 | cut -d'.' -f1,2)
        if [[ "$PY_VER" == "$REQUIRED_PYTHON" ]]; then
            PYTHON_BIN="$py"
            break
        fi
    fi
done

if [[ -z "$PYTHON_BIN" ]]; then
    error "Python {{ python_version }} not found. Install it first: https://www.python.org/downloads/"
fi
info "Python $($PYTHON_BIN --version) found at $(which $PYTHON_BIN)"

# pip check
if ! "$PYTHON_BIN" -m pip --version >/dev/null 2>&1; then
    error "pip not found for $PYTHON_BIN. Install pip: https://pip.pypa.io/en/stable/installation/"
fi

{% if cuda_version %}
# CUDA check (informational — won't abort if missing)
if command -v nvidia-smi >/dev/null 2>&1; then
    DRIVER_VER=$(nvidia-smi --query-gpu=driver_version --format=csv,noheader 2>/dev/null | head -1 || echo "unknown")
    info "NVIDIA driver: $DRIVER_VER"
else
    warn "nvidia-smi not found. GPU support may be unavailable."
fi
{% endif %}

# ── Virtual environment ───────────────────────────────────────────────────────
VENV_DIR=".venv"
if [[ ! -d "$VENV_DIR" ]]; then
    info "Creating virtual environment in $VENV_DIR..."
    "$PYTHON_BIN" -m venv "$VENV_DIR"
fi

# Activate virtual environment
source "$VENV_DIR/bin/activate"
info "Virtual environment activated: $VENV_DIR"
RUN_CMD=""
{% endif %}

# Upgrade pip inside venv
${RUN_CMD}pip install --quiet --upgrade pip

{% if use_uv %}
# ── Bootstrap uv ─────────────────────────────────────────────────────────────
info "Bootstrapping uv package manager..."
if ! command -v uv >/dev/null 2>&1; then
    curl -LsSf https://astral.sh/uv/install.sh | sh
    source "$HOME/.local/bin/env"
    info "uv installed successfully."
else
    info "uv already installed: $(uv --version)"
fi
{% endif %}

# ── Package installation ──────────────────────────────────────────────────────
info "Installing packages..."

{% if cuda_version %}
# PyTorch CUDA index (required for CUDA-specific builds)
TORCH_INDEX="https://download.pytorch.org/whl/cu{{ cuda_version | replace('.', '') }}"

{% if use_uv %}
${RUN_CMD}uv pip install \
{% else %}
${RUN_CMD}pip install \
{% endif %}
{% for pkg in packages %}
{% if pkg.cuda_variant %}
    "{{ pkg.pip_spec }}" \
{% endif %}
{% endfor %}
    --index-url "$TORCH_INDEX"

# Install remaining packages from PyPI
{% if use_uv %}
${RUN_CMD}uv pip install \
{% else %}
${RUN_CMD}pip install \
{% endif %}
{% for pkg in packages %}
{% if not pkg.cuda_variant %}
    "{{ pkg.pip_spec }}" \
{% endif %}
{% endfor %}
    --quiet
{% else %}
# CPU-only installation
{% if use_uv %}
${RUN_CMD}uv pip install \
{% else %}
${RUN_CMD}pip install \
{% endif %}
{% for pkg in packages %}
    "{{ pkg.pip_spec }}" \
{% endfor %}
    --quiet
{% endif %}

# ── Post-install summary ──────────────────────────────────────────────────────
info "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
info "✓ EnvForge setup complete!"
info "  Profile : {{ profile.name }}"
info "  Python  : $(${RUN_CMD}python --version)"
{% if use_micromamba %}
info "  Env     : micromamba ($ENV_PREFIX)"
{% elif use_uv %}
info "  Installer: uv (fast)"
{% else %}
info "  Installer: pip"
{% endif %}
{% if cuda_version %}
info "  CUDA    : {{ cuda_version }}"
{% endif %}
info "  Venv    : $PWD/.venv"
info ""
{% if use_micromamba %}
info "  Activate with:  micromamba activate -p .venv"
{% else %}
info "  Activate with:  source .venv/bin/activate"
{% endif %}
info "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
{% if warnings %}

# ── Warnings ──────────────────────────────────────────────────────────────────
{% for warning in warnings %}
warn "{{ warning }}"
{% endfor %}
{% endif %}
